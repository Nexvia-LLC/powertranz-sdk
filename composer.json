{
    "name": "nexvia-llc/powertranz-sdk",
    "description": "Production-grade PHP SDK for the PowerTranz payment gateway. Full request/response field coverage, SPI 3DS, HPP, fraud check, recurring, BrowserInfo, and the full transaction lifecycle (auth, capture, refund, void, lookup, search).",
    "type": "library",
    "keywords": ["powertranz", "payment", "gateway", "3ds", "hpp", "fraud-check", "caribbean", "sdk"],
    "license": "proprietary",
    "homepage": "https://github.com/Nexvia-LLC/powertranz-sdk",
    "support": {
        "issues": "https://github.com/Nexvia-LLC/powertranz-sdk/issues",
        "source": "https://github.com/Nexvia-LLC/powertranz-sdk"
    },
    "authors": [
        {
            "name": "Zachary Clarke",
            "email": "zacharyclarke4912@yahoo.com",
            "role": "Lead Engineer"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "ext-curl": "*",
        "guzzlehttp/guzzle": "^7.5",
        "psr/log": "^3.0|^2.0",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "PowerTranz\\": "src/"
        },
        "classmap": [
            "src/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "PowerTranz\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "PowerTranz\\Laravel\\PowerTranzServiceProvider"
            ],
            "aliases": {
                "PowerTranz": "PowerTranz\\Laravel\\Facades\\PowerTranz"
            }
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "suggest": {
        "illuminate/support": "Required for Laravel integration (^10.0|^11.0|^12.0)."
    }
}
